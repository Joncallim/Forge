.DS_Store
# Track only .forge/runs/<issue>/<runId>.json; keep other .forge output ignored.
.forge/*
!.forge/runs/
.forge/runs/**
!.forge/runs/**/
!.forge/runs/*/*.json
local-memory/

# Local agent worktrees (scratch checkouts created during development)
.claude/worktrees/

# Local environment / secrets — the installer writes secrets to ./.env
.env
.env.*
!.env.example
