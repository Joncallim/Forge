# ----------------------------------------------------------------------------
# Provider API keys are now entered in the Forge web UI (Providers page) and
# stored encrypted in the database — you do NOT need to set them here. The
# variables below are an optional fallback for headless/CI setups; a key entered
# in the UI always takes precedence. On macOS, prefer: bash scripts/install-mac.sh
# ----------------------------------------------------------------------------

# Anthropic — optional cloud provider for planning and review
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — optional cloud provider
OPENAI_API_KEY=sk-...

# OpenRouter — routes requests to worker models (Option A: cloud routing)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Custom OpenAI-compatible helper model endpoint
# In Forge, choose Provider type = Custom, Base URL = your endpoint, and
# API key environment variable = CUSTOM_MODEL_API_KEY.
CUSTOM_MODEL_API_KEY=sk-custom-...

# LiteLLM — self-hosted OpenAI-compatible gateway (Option B: local/hybrid routing)
# Run via: docker compose up litellm
# Supports Ollama backends, cloud APIs, and fallback chains
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=                        # optional — set in litellm_config.yaml if auth enabled

# GitHub — PR creation and merge operations
GITHUB_TOKEN=ghp_...
GITHUB_REPO=owner/repo

# PostgreSQL — long-term memory and task history.
# Use this localhost URL when running the web app/worker directly on your host.
# Docker Compose services use the internal postgres hostname automatically.
POSTGRES_USER=forge
POSTGRES_PASSWORD=change_me
POSTGRES_DB=forge
DATABASE_URL=postgresql://forge:change_me@localhost:5432/forge

# Redis — job queues and agent scheduling.
# Use localhost on the host; Docker Compose services use redis://redis:6379/0.
REDIS_URL=redis://localhost:6379/0

# Web UI — Next.js app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Silence Next.js's anonymous telemetry notice on first dev run
NEXT_TELEMETRY_DISABLED=1

# Worker — Redis claim timeout for the dedicated task helper
FORGE_WORKER_CLAIM_TIMEOUT_SECONDS=5

# Agent prompt files — set to an absolute path for standalone Next.js deployments
# Defaults to ../../.claude/agents relative to the web process cwd
FORGE_AGENT_CONFIG_DIR=/absolute/path/to/Forge/.claude/agents

# Session — 32-byte hex secret for HMAC session signing
# Generate with: openssl rand -hex 32
# Also used to derive the encryption key for provider API keys stored in the DB.
SESSION_SECRET=change_me_generate_with_openssl_rand_hex_32

# Optional — dedicated key for encrypting stored secrets. If unset, the key is
# derived from SESSION_SECRET. Set this if you want to rotate it independently.
# FORGE_ENCRYPTION_KEY=

# WebAuthn / Passkeys — must match your deployment domain
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Forge
WEBAUTHN_ORIGIN=http://localhost:3000
