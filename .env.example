# ----------------------------------------------------------------------------
# Provider API keys are entered in the Forge web UI (Providers page) and
# stored encrypted in the database — you do NOT need to set them here. The
# variables below are an optional fallback for headless/CI setups; a key entered
# in the UI always takes precedence. For local install, prefer:
# bash scripts/install.sh
# ----------------------------------------------------------------------------

# Anthropic — optional cloud provider for planning and review
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI — optional cloud provider
OPENAI_API_KEY=sk-...

# OpenRouter — routes requests to worker models (Option A: cloud routing)
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Custom OpenAI-compatible helper model endpoint
# In Forge, choose Provider type = Custom, Base URL = your endpoint, and enter
# any required API key in the Providers page so Forge stores it encrypted.

# LiteLLM — self-hosted OpenAI-compatible gateway (Option B: local/hybrid routing)
# Run via: docker compose up litellm
# Supports Ollama backends, cloud APIs, and fallback chains
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=                        # optional — set in litellm_config.yaml if auth enabled

# GitHub — PR creation, merge operations, and clone fallback.
# Clone env-var fallback is allowlisted to GITHUB_TOKEN, GH_TOKEN, GITHUB_PAT,
# or FORGE_GITHUB_TOKEN. Prefer the web UI PAT or an authenticated gh CLI.
GITHUB_TOKEN=ghp_...
GITHUB_REPO=owner/repo

# PostgreSQL — long-term memory and task history.
# Use this localhost URL when running the web app/worker directly on your host.
# Docker Compose services use the internal postgres hostname automatically.
POSTGRES_USER=forge
POSTGRES_PASSWORD=change_me
POSTGRES_DB=forge
DATABASE_URL=postgresql://forge:change_me@localhost:5432/forge

# Redis — job queues and agent scheduling.
# Use localhost on the host; Docker Compose services use redis://redis:6379/0.
REDIS_URL=redis://localhost:6379/0

# Web UI — Next.js app
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Silence Next.js's anonymous telemetry notice on first dev run
NEXT_TELEMETRY_DISABLED=1

# Worker — Redis claim timeout for the dedicated task helper
FORGE_WORKER_CLAIM_TIMEOUT_SECONDS=5
# Work-package execution and local repository writes are enabled by default.
# Set either value to 0, false, off, no, or disabled when you want approval to
# produce reviewable handoff artifacts without running specialists or applying
# generated files.
# FORGE_WORK_PACKAGE_EXECUTION=1
# FORGE_HOST_REPOSITORY_WRITES=1
# ACP package execution is enabled after task approval. Set this to 0 when local
# adapter process access is not acceptable; ACP is not OS-confined by Forge.
# FORGE_ACP_WORK_PACKAGE_EXECUTION=0

# Workspace root — where Forge stores user-owned operational files: projects,
# MCP manifests, editable agent prompts, workforce exports, runtime registry
# files, logs, backups, and global-settings.json. When unset, defaults to
# ~/Documents/Forge and can be changed from Settings.
# FORGE_WORKSPACE_ROOT=/absolute/path/to/Documents/Forge
# Optional display alias for containerized or temporary workspace mounts. The
# server still uses FORGE_WORKSPACE_ROOT for filesystem operations, but the UI
# shows this path for workspace-owned files.
# FORGE_WORKSPACE_DISPLAY_ROOT=~/Documents/Forge

# Agent prompt files — optional advanced override. When unset, Forge writes
# editable prompts to ~/Documents/Forge/prompts/agents. If set, this path must
# stay inside the active Forge workspace root.
# FORGE_AGENT_CONFIG_DIR=/absolute/path/to/Documents/Forge/prompts/agents

# Install/upgrade prompt behavior. The installer keeps local workspace prompts
# by default; set overwrite only when you want repository defaults to replace
# local prompt edits after a timestamped backup.
# FORGE_PROMPT_UPGRADE_MODE=keep

# Session — 32-byte hex secret for local session/security material.
# Generate with: openssl rand -hex 32
# Also used to derive the encryption key for provider API keys stored in the DB.
SESSION_SECRET=change_me_generate_with_openssl_rand_hex_32

# Optional — dedicated key for encrypting stored secrets. If unset, the key is
# derived from SESSION_SECRET. Set this if you want to rotate it independently.
# FORGE_ENCRYPTION_KEY=

# WebAuthn / Passkeys — must match your deployment domain.
# Password login stores only a password hash in PostgreSQL and does not require
# a separate environment variable.
# Set FORGE_TRUST_PROXY=1 only when a trusted reverse proxy controls
# X-Forwarded-For / X-Real-IP headers for password-login throttling.
# FORGE_TRUST_PROXY=0
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME=Forge
WEBAUTHN_ORIGIN=http://localhost:3000
